# ============================================================================
#  Fichier .env de PRODUCTION (o2switch) — à copier en `.env` sur le serveur,
#  puis remplacer les valeurs entre < >. NE JAMAIS committer le vrai .env.
# ============================================================================

APP_NAME="Pétanque Manager"
APP_ENV=production
APP_KEY=                         # généré une fois par `php artisan key:generate`
APP_DEBUG=false
APP_URL=https://<ton-domaine.fr>

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR

LOG_CHANNEL=stack
LOG_LEVEL=error

# --- Base de données MySQL (créée depuis le cPanel o2switch) ---------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=<nom_de_la_base>
DB_USERNAME=<utilisateur_mysql>
DB_PASSWORD=<mot_de_passe_mysql>

# --- Sessions / cache / files : en base (pas de Redis en mutualisé) --------
SESSION_DRIVER=database
SESSION_LIFETIME=120
CACHE_STORE=database

# En mutualisé, pas de worker permanent : les diffusions temps réel partent
# directement pendant la requête (sync). Simple et suffisant pour des concours.
QUEUE_CONNECTION=sync

# --- Temps réel : Pusher (hébergé, offre gratuite) -------------------------
BROADCAST_CONNECTION=pusher
PUSHER_APP_ID=<pusher_app_id>
PUSHER_APP_KEY=<pusher_app_key>
PUSHER_APP_SECRET=<pusher_app_secret>
PUSHER_APP_CLUSTER=eu

# Exposées au build du front (npm run build) : le navigateur se connecte au
# WebSocket de Pusher avec ces valeurs. Doivent être présentes AU MOMENT DU BUILD.
VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# --- E-mails (facultatif au lancement) : `log` = pas d'envoi réel ----------
# Pour de vrais e-mails (reset mot de passe…), renseigner un service SMTP.
MAIL_MAILER=log
MAIL_FROM_ADDRESS="no-reply@<ton-domaine.fr>"
MAIL_FROM_NAME="${APP_NAME}"

FILESYSTEM_DISK=local
